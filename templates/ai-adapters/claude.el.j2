;; Generated by emaw | Profile: {{ config.profile }}
;; Do not edit -- regenerate with: emaw sync

;; vterm is required by claude-code.el as a terminal emulator backend
(use-package vterm
  :ensure t)

;; claude-code.el wraps the `claude` CLI in a vterm buffer.
;; Install the CLI first:  npm install -g @anthropic-ai/claude-code
(use-package claude-code
  :ensure t
  :after vterm
  :config
  (setq claude-code-program "claude")
  (setq claude-code-args '()))

;; C-c C-a  AI prefix keymap (emaw convention)
(define-prefix-command 'emaw-ai-map)
(global-set-key (kbd "C-c C-a") 'emaw-ai-map)

;; c  open / focus Claude chat session
(define-key emaw-ai-map (kbd "c") #'claude-code)

;; s  send active region to Claude
(define-key emaw-ai-map (kbd "s") #'claude-code-send-region)

;; b  send entire buffer to Claude
(define-key emaw-ai-map (kbd "b") #'claude-code-send-buffer)

(message "emaw: Claude Code adapter loaded (C-c C-a for commands)")
