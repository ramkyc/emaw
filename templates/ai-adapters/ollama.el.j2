;; ollama-adapter.el --- Ollama integration via gptel
;; Generated by emaw | Profile: {{ config.profile }}
;; Do not edit -- regenerate with: emaw sync

;; gptel is a multi-backend LLM client with first-class Ollama support.
;; Requires Ollama running locally:  ollama serve
;; Pull a model first:               ollama pull llama3.2
(use-package gptel
  :ensure t
  :config
  (setq gptel-backend
        (gptel-make-ollama "Ollama"
          :host "localhost:11434"
          :stream t
          :models '(llama3.2:latest))
        gptel-model 'llama3.2:latest))

;; C-c C-a  AI prefix keymap (emaw convention)
(define-prefix-command 'emaw-ai-map)
(global-set-key (kbd "C-c C-a") 'emaw-ai-map)

;; c  open gptel chat buffer
(define-key emaw-ai-map (kbd "c") #'gptel)

;; s  send region or buffer to Ollama
(define-key emaw-ai-map (kbd "s") #'gptel-send)

;; r  rewrite selected region in-place
(define-key emaw-ai-map (kbd "r") #'gptel-rewrite)

(message "emaw: Ollama adapter loaded via gptel (C-c C-a for commands)")
