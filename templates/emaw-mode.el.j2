;;; emaw-mode.el --- Emacs AI Workspace Minor Mode -*- lexical-binding: t -*-
;;
;; Generated by emaw | Do not edit manually

;;; Commentary:
;;
;; Provides integration with the external `emaw` CLI tool.
;; M-x emaw-doctor
;; M-x emaw-init

;;; Code:

(defgroup emaw nil
  "Emacs AI Workspace settings."
  :group 'tools)

(defvar emaw--last-task-status nil
  "Last completed task name and result string shown in the mode-line.
 Example: \"run-tests [SUCCESS]\"")

(defun emaw--task-sentinel (proc event task-name)
  "Sentinel for emaw task processes.
Updates `emaw--last-task-status' and the mode-line on process completion.
PROC is the process, EVENT is the event string, TASK-NAME is the task label."
  (when (memq (process-status proc) '(exit signal))
    (let* ((buf     (process-buffer proc))
           (content (if (buffer-live-p buf)
                        (with-current-buffer buf (buffer-string))
                      ""))
           (success (string-match-p "\\[SUCCESS\\]" content))
           (label   (if success "[SUCCESS]" "[FAILED]")))
      (setq emaw--last-task-status (format "%s %s" task-name label))
      (force-mode-line-update t)
      (message "emaw: task %s %s" task-name label))))

(defun emaw--run-task (task-name)
  "Start `emaw task TASK-NAME' with a sentinel for status tracking."
  (let* ((buf-name (format "*emaw-task-%s*" task-name))
         (buf      (get-buffer-create buf-name))
         (root     (or (locate-dominating-file default-directory ".emaw")
                       default-directory))
         (proc     (let ((default-directory root))
                     (start-process-shell-command
                      (format "emaw-task-%s" task-name)
                      buf
                      (format "emaw task %s" task-name)))))
    (pop-to-buffer buf)
    (set-process-sentinel
     proc
     (lambda (p e)
       (emaw--task-sentinel p e task-name)))))

(defun emaw-doctor ()
  "Run the emaw doctor validations and show the output."
  (interactive)
  (let ((default-directory (or (locate-dominating-file default-directory ".emaw") default-directory)))
    (async-shell-command "emaw doctor" "*emaw-doctor*")))

(defun emaw-init ()
  "Run the emaw init configuration process and show the output."
  (interactive)
  (let ((default-directory (or (locate-dominating-file default-directory ".emaw") default-directory)))
    (async-shell-command "emaw init" "*emaw-init*")))

(defun emaw-sync ()
  "Run the emaw sync synchronization process and show the output."
  (interactive)
  (let ((default-directory (or (locate-dominating-file default-directory ".emaw") default-directory)))
    (async-shell-command "emaw sync" "*emaw-sync*")))

{% for task_name, task_cmd in reqs.task_commands.items() %}
(defun emaw-task-{{ task_name }} ()
  "Run the {{ task_name }} task (`{{ task_cmd }}') and show the output."
  (interactive)
  (emaw--run-task "{{ task_name }}"))
{% endfor %}

(defvar emaw-mode-map
  (let ((map (make-sparse-keymap)))
    ;; We use C-c C-e as the prefix map
    (define-prefix-command 'emaw-prefix-map)
    (define-key map (kbd "C-c C-e") 'emaw-prefix-map)
    (define-key map (kbd "C-c C-e d") #'emaw-doctor)
    (define-key map (kbd "C-c C-e i") #'emaw-init)
    (define-key map (kbd "C-c C-e s") #'emaw-sync)
    
    (define-prefix-command 'emaw-task-prefix-map)
    (define-key map (kbd "C-c C-e t") 'emaw-task-prefix-map)
    {% for task_name, task_cmd in reqs.task_commands.items() %}
    (define-key map (kbd "C-c C-e t {{ loop.index }}") #'emaw-task-{{ task_name }})
    {% endfor %}
    map)
  "Keymap for `emaw-mode'.")

;;;###autoload
(define-minor-mode emaw-mode
  "Minor mode for Emacs AI Workspace workflows."
  :init-value nil
  :lighter (:eval (concat " emaw"
                          (when emaw--last-task-status
                            (concat ":" emaw--last-task-status))))
  :keymap emaw-mode-map
  :global nil)

(provide 'emaw-mode)
;;; emaw-mode.el ends here
