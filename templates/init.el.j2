;; init.el --- Auto-generated Emacs AI Workspace
;; Profile: {{ config.profile }}
;; AI Provider: {{ config.ai_provider }}

;; Package initialization
(require 'package)
(setq package-archives '(("melpa" . "https://melpa.org/packages/")
                         ("gnu" . "https://elpa.gnu.org/packages/")
                         ("nongnu" . "https://elpa.nongnu.org/nongnu/")))
(package-initialize)

;; Install use-package if not present
(unless (package-installed-p 'use-package)
  (package-refresh-contents)
  (package-install 'use-package))
(eval-when-compile (require 'use-package))
(setq use-package-always-ensure t)

;; Resolved Emacs Packages from ProfileRequirements
{% for pkg in reqs.emacs_packages %}
(use-package {{ pkg }})
{% endfor %}

;; Load task commands mapping
(message "Workspace booted. Available task commands:")
{% for cmd in reqs.task_commands %}
(message "- {{ cmd }}")
{% endfor %}

;; AI Adapter Integration
{% if reqs.ai_adapters %}
{% for adapter in reqs.ai_adapters %}
(let ((adapter-file (expand-file-name "{{ adapter }}-adapter.el"
                      (file-name-directory (or load-file-name buffer-file-name)))))
  (if (file-exists-p adapter-file)
      (load-file adapter-file)
    (message "emaw: adapter file not found: %s" adapter-file)))
{% endfor %}
{% else %}
(message "emaw: no AI adapter configured")
{% endif %}

;; Load EMAW minor mode
(let ((emaw-mode-file (expand-file-name "emaw-mode.el"
                        (file-name-directory (or load-file-name buffer-file-name)))))
  (if (file-exists-p emaw-mode-file)
      (progn
        (load-file emaw-mode-file)
        (add-hook 'prog-mode-hook #'emaw-mode))
    (message "emaw: emaw-mode.el not found")))
